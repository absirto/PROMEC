{
  "name": "promec-backend",
  "version": "1.0.0",
  "main": "dist/src/server.js",
  "scripts": {
    "postinstall": "npx prisma generate && npm run build",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "npx prisma migrate deploy && node dist/src/server.js",
    "prisma": "prisma",
    "test": "jest --runInBand",
    "openapi:export": "ts-node --transpile-only scripts/tools/write-openapi.ts",
    "permissions:sync": "tsx scripts/maintenance/sync-group-permissions.ts",
    "permissions:check": "node scripts/maintenance/permissions/check_permissions.js",
    "permissions:seed": "node scripts/maintenance/permissions/seed_permissions.js",
    "permissions:migrate-pt": "node scripts/maintenance/permissions/migrate_permissions_to_pt.js",
    "permissions:grant-full": "node scripts/maintenance/permissions/give_full_access.js",
    "maintenance:recalculate-totals": "node scripts/maintenance/permissions/recalculate_totals.js",
    "worker": "node dist/src/worker.js",
    "worker:dev": "ts-node src/worker.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@sentry/node": "^10.47.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/pdfkit": "^0.13.4",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "bull": "^4.16.5",
    "cors": "^2.8.6",
    "date-fns": "^3.6.0",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "pdfkit": "^0.15.0",
    "prisma": "^6.19.3",
    "redis": "^5.11.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typescript": "^5.7.2",
    "winston": "^3.19.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@bull-board/api": "^6.21.0",
    "@bull-board/express": "^6.21.0",
    "@types/jest": "^30.0.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.19.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
