PORT=3001
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/promec_db?schema=public"
# Mínimo 32 caracteres. Gere com: openssl rand -base64 48
JWT_SECRET="sua_chave_secreta_aqui_com_no_minimo_32_chars"
REDIS_URL="redis://localhost:6379"
SENTRY_DSN=""
ALLOW_PUBLIC_REGISTER="false"
ALLOW_PUBLIC_EXTERNAL_LOOKUP="false"
# Origens permitidas para CORS (separadas por vírgula). Vazio = bloqueia tudo em produção.
# Ex: ALLOWED_ORIGINS="https://app.empresa.com,https://admin.empresa.com"
ALLOWED_ORIGINS=""
# development | production (em Ubuntu/servidor use production atrás de Nginx)
NODE_ENV="development"
