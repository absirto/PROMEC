PORT=3001
NODE_ENV=production

# Gere com: openssl rand -base64 48
JWT_SECRET=troque_por_um_secret_forte_com_32_chars_ou_mais

# Banco publicado apenas dentro da rede do docker-compose
POSTGRES_PASSWORD=troque_por_uma_senha_forte
DATABASE_URL=postgresql://postgres:troque_por_uma_senha_forte@db:5432/promec_db?schema=public
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# CORS do frontend
ALLOWED_ORIGINS=https://seudominio.com.br,https://www.seudominio.com.br

# Rotas públicas
ALLOW_PUBLIC_REGISTER=false
ALLOW_PUBLIC_EXTERNAL_LOOKUP=false

# Opcional
SENTRY_DSN=
SWAGGER_SERVER_URL=https://api.seudominio.com.br

# Uploads de qualidade dentro do container
QC_UPLOAD_DIR=/app/uploads/quality