{
  "name": "frontend-vite",
  "version": "1.2.0",
  "private": true,
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.15.0",
    "lucide-react": "^0.367.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.75.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1",
    "socket.io-client": "^4.8.3",
    "xlsx": "^0.18.5"
  },
  "scripts": {
    "start": "vite",
    "build": "tsc && vite build",
    "generate:api-types": "openapi-typescript ../openapi/v1.json -o src/generated/api-v1.ts",
    "test": "vitest run",
    "docker:build": "docker build -t promec-frontend .",
    "docker:run": "docker run --rm -p 3000:80 promec-frontend",
    "docker:build:prod-api": "docker build --build-arg VITE_API_URL=https://api.ucalcom.com/v1 -t promec-frontend .",
    "ops:install": "bash scripts/ops/install_frontend.sh"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/css-modules": "^1.0.5",
    "@types/react-dom": "^18.2.7",
    "@types/react-icons": "^2.2.7",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^4.3.0",
    "cypress": "^12.17.4",
    "jsdom": "^24.1.0",
    "openapi-typescript": "^7.6.1",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^1.6.0"
  }
}
