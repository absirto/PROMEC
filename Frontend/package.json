{
  "name": "frontend-cra",
  "version": "1.2.0",
  "private": true,
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.15.0",
    "lucide-react": "^0.367.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.75.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.14.0",
    "react-scripts": "5.0.1",
    "recharts": "^3.8.1",
    "socket.io-client": "^4.8.3",
    "web-vitals": "^2.1.4",
    "xlsx": "^0.18.5"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "generate:api-types": "openapi-typescript ../openapi/v1.json -o src/generated/api-v1.ts",
    "test": "react-scripts test",
    "docker:build": "docker build -t promec-frontend .",
    "docker:run": "docker run --rm -p 3000:80 promec-frontend",
    "docker:build:prod-api": "docker build --build-arg REACT_APP_API_URL=https://api.ucalcom.com/v1 -t promec-frontend .",
    "ops:install": "bash scripts/ops/install_frontend.sh",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/css-modules": "^1.0.5",
    "@types/jest": "^29.5.11",
    "@types/react-dom": "^18.2.7",
    "@types/react-icons": "^2.2.7",
    "@types/react-router-dom": "^5.3.3",
    "cypress": "^12.17.4",
    "openapi-typescript": "^7.6.1",
    "typescript": "^5.4.5"
  }
}
